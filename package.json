{
  "name": "lingjijianying",
  "productName": "灵机剪影",
  "version": "1.3.0",
  "main": "dist-electron/main.js",
  "bin": {
    "lingji": "dist-cli/lingji.mjs"
  },
  "scripts": {
    "ensure:electron": "node scripts/ensure-electron-binary.cjs",
    "dev": "node scripts/ensure-electron-binary.cjs && node scripts/dev-windows-utf8.cjs",
    "clean:build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true});require('node:fs').rmSync('dist-electron',{recursive:true,force:true});\"",
    "build": "npm run clean:build && electron-vite build && node scripts/obfuscate-build.cjs",
    "package:win": "node scripts/package-windows.cjs",
    "package:mac": "node scripts/package-mac.cjs",
    "dmg:mac": "node scripts/make-dmg-mac.cjs",
    "dist:win": "npm run ensure:electron && npm run build && npm run build:cli && npm run package:win",
    "dist:mac": "npm run build && npm run build:cli && npm run package:mac",
    "dist:dmg:mac": "npm run dist:mac && npm run dmg:mac",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:cli": "node scripts/build-cli.cjs",
    "install:cli": "npm run build:cli && npm link",
    "uninstall:cli": "npm unlink -g lingjijianying"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "description": "",
  "devDependencies": {
    "@electron/packager": "^19.1.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/diff": "^7.0.2",
    "@types/diff-match-patch": "^1.0.36",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^41.1.0",
    "electron-vite": "^5.0.0",
    "javascript-obfuscator": "^5.4.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^7.3.1",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@babel/standalone": "^7.29.2",
    "@base-ui/react": "^1.0.0",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@earendil-works/pi-coding-agent": "0.79.1",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@langchain/anthropic": "^1.4.0",
    "@langchain/core": "^1.1.39",
    "@langchain/google-genai": "^2.1.27",
    "@langchain/openai": "^1.4.3",
    "@lezer/highlight": "^1.2.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@remotion/bundler": "^4.0.469",
    "@remotion/player": "^4.0.469",
    "@remotion/renderer": "^4.0.469",
    "@shikijs/rehype": "^4.0.2",
    "@uiw/react-md-editor": "^4.0.0",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "diff": "^8.0.4",
    "diff-match-patch": "^1.0.5",
    "esbuild": "^0.28.0",
    "fabric": "^6.9.1",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "font-list": "^1.6.0",
    "framer-motion": "^12.38.0",
    "gsap": "^3.15.0",
    "jsonrepair": "^3.14.0",
    "lucide-react": "^0.556.0",
    "node-pty": "^1.1.0",
    "playwright": "^1.61.0",
